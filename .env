# ============================================================================
# Qwen 测试环境变量配置
# 你可以随时修改这组变量，切换测试不同模型，并保存到不同输出文件夹中！
# ----------------------------------------------------------------------------
# 用法：修改完后保存该文件，运行 stop.bat，再运行 start.bat。
# ============================================================================

# 1. 你想要测试的模型所在文件夹名称（必须在 model/ 目录下）
# 可选值：
#   - PaddleOCR-VL-1.6        (PaddleOCR 专用 OCR 模型, 0.9B)
#   - Qwen3.5-4B-AWQ-4bit     (Qwen 通用多模态模型, 4B)
#   - Qwen3.5-4B-FP8
# 2. 本地模型目录名
#    示例: Qwen3.5-4B-AWQ-4bit
MODEL_DIR=Qwen3.5-4B-AWQ-4bit

# 2. 对应的输出文件夹（用于隔离不同模型的输出结果）
# 可选值：
#   - output_4b_awq
#   - output_4b_fp8
OUTPUT_DIR=output

# 3. vLLM 极限调优参数 (根据需要修改测试)
# 最大并发数 (如果遇到 Preemption 警告，请调低；你想测极限可以调到 16 或 32)
MAX_NUM_SEQS=16
# 分块预填充的 Token 预算 (越大首字越快，但占用显存更多，推荐 2048-4096)
MAX_BATCHED_TOKENS=4096

# ============================================================================
# 性能与显存配置 (针对 8GB 小显存设备优化)
# ============================================================================

# 3. 显存分配比例 (0.0 到 1.0)
# 默认 0.85。如果你在 8GB 显存的设备上遇到 OutOfMemory (OOM) 报错，
# 请降低此数值（例如改为 0.8 或者 0.75）以给系统留出更多显存。
# 如果是完全纯粹的推理专用机，可以开到 0.9。
GPU_MEMORY_UTILIZATION=0.85

# 4. 模型最大上下文长度 (控制 KV Cache 的显存占用)
# 默认 16384。如果你要部署到 8GB 显存设备，特别是跑 9B 这样的大模型时，
# 建议大幅降低此数值（改为 8192 或 4096），否则 KV Cache 会直接撑爆显存！
MAX_MODEL_LEN=25000

# 5. KV 缓存量化精度 (大幅节省长文本显存)
# 可选值：auto (默认 FP16), fp8, fp8_e5m2
# 建议设置：如果你的显卡支持(如 RTX 40系/30系)，强烈建议设为 fp8，
# 这样在进行极长文本的 JSON 抽取时，KV Cache 的显存占用直接减半！
KV_CACHE_DTYPE=fp8